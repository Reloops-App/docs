          "ai/ai-tagging"
        ]
      },
      {
        "group": "Collections",
        "icon": "layout-grid",
        "expanded": true,
        "pages": [
          "collections/collections-overview",
          "collections/build-and-style-collections"
        ]
      },
      {
        "group": "Review & Sharing",
        "icon": "message-circle",
        "expanded": true,
